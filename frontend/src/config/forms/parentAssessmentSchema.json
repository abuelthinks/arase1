{
    "id": "parent_assessment",
    "title": "Parent Assessment Form",
    "type": "assessment",
    "role": "parent",
    "sections": [
        {
            "id": "section_b",
            "title": "SECTION B. DEVELOPMENTAL HISTORY",
            "fields": [
                {
                    "id": "sitting",
                    "label": "Sitting",
                    "type": "radio",
                    "options": [
                        "Early",
                        "Typical",
                        "Late"
                    ]
                },
                {
                    "id": "crawling",
                    "label": "Crawling",
                    "type": "radio",
                    "options": [
                        "Early",
                        "Typical",
                        "Late",
                        "Did not crawl"
                    ]
                },
                {
                    "id": "walking",
                    "label": "Walking",
                    "type": "radio",
                    "options": [
                        "Early",
                        "Typical",
                        "Late"
                    ]
                },
                {
                    "id": "first_words",
                    "label": "First Words",
                    "type": "radio",
                    "options": [
                        "Early",
                        "Typical",
                        "Late"
                    ]
                },
                {
                    "id": "phrases_sentences",
                    "label": "Phrases/Sentences",
                    "type": "radio",
                    "options": [
                        "Early",
                        "Typical",
                        "Late"
                    ]
                },
                {
                    "id": "previous_services",
                    "label": "Previous Services",
                    "type": "checkbox_group",
                    "options": [
                        "Schooling before",
                        "Speech Therapy",
                        "Occupational Therapy",
                        "Behavioral Therapy"
                    ]
                },
                {
                    "id": "had_iep_before",
                    "label": "Has your child had an Individualized Education Program (IEP) before?",
                    "type": "radio",
                    "options": [
                        "Yes",
                        "No"
                    ]
                },
                {
                    "id": "iep_details",
                    "label": "IEP Details (if yes)",
                    "type": "text"
                },
                {
                    "id": "developmental_concerns",
                    "label": "Areas of Concern",
                    "type": "checkbox_group",
                    "options": [
                        "Communication",
                        "Learning",
                        "Motor Skills",
                        "Social",
                        "Behavior",
                        "Emotions",
                        "Sensory",
                        "Daily Living",
                        "Safety",
                        "Not sure"
                    ]
                }
            ]
        },
